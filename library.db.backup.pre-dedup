inal": null, "exif_latitude": -33.45521, "exif_longitude": -70.59388, "exif_device_id": null, "exif_lens_model": null, "exif_iso": null, "exif_aperture": null, "exif_shutter_speed": null, "exif_focal_length": null, "exif_lens_make": null, "processed": false, "matched_catalog_key": null, "vision_result": null, "vision_score": null, "processed_at": null, "added_at": "2026-03-21T22:47:20.994670", "post_url": null}, "435": {"media_key": "other/17921130539535398", "file_path": "/home/cristian/instagram-dump/media/other/17921130539535398.jpg", "filename": "17921130539535398.jpg", "date_folder": null, "caption": "Tomorrow will be a special day in my country, we will decide if we want the new constitution or the one was created during the dictatorship of Pinochet.\nTomorrow I voted for the new one. Without hesitation because I believe in what the people create and believe.\nThis photo was taken in the closing event of the apruebo campaign.\nLet\u00e2\u0080\u0099s win this Sunday\n#apruebo #apruebodesalida", "created_at": "2022-09-03T13:12:18", "creation_timestamp": 1662225138, "exif_data": {"latitude": -33.440132, "longitude": -70.64342}, "exif_date_time_original": null, "exif_latitude": -33.440132, "exif_longitude": -70.64342, "exif_device_id": null, "exif_lens_model": null, "exif_iso": null, "exif_aperture": null, "exif_shutter_speed": null, "exif_focal_length": null, "exif_lens_make": null, "processed": false, "matched_catalog_key": null, "vision_result": null, "vision_score": null, "processed_at": null, "added_at": "2026-03-21T22:47:21.001733", "post_url": null}, "436": {"media_key": "other/17928197021170198", "file_path": "/home/cristian/instagram-dump/media/other/17928197021170198.webp", "filename": "17928197021170198.webp", "date_folder": null, "caption": "The first time that I heard @thestrokes in live concert. Such a good experience very impressed with their show and how they interact with the crowd.\n.\n.\n.\nFujifilm x100v\n#rockalparque #concertband #dronephotog