# Backend API Configuration
# Copy this file to .env and set your absolute paths

# REQUIRED: Path to the main library database
# Use absolute path, not relative
LIBRARY_DB=/path/to/your/library.db

# OPTIONAL: Path to visualizer-specific database
DATABASE_PATH=../visualizer.db

# Flask server settings
FLASK_HOST=localhost
FLASK_PORT=5000
FLASK_DEBUG=true

# Frontend URLs for CORS (comma-separated)
FRONTEND_URL=http://localhost:5173,http://localhost:5174

# Directories
INSTAGRAM_DIR=/tmp/instagram_images
THUMBNAIL_DIR=../thumbnails
