{
  "version": 1,
  "hooks": {
    "beforeShellExecution": [
      {
        "command": ".cursor/hooks/safe-kill-port.sh",
        "matcher": "kill|lsof.*xargs.*kill|pkill",
        "failClosed": true
      },
      {
        "command": ".cursor/hooks/enforce-browser-harness.sh",
        "matcher": "playwright",
        "failClosed": true
      }
    ]
  }
}
